# === LLM ===
ZHIPU_API_KEY=your-zhipuai-api-key
ZHIPU_MODEL=glm-4
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# === PostgreSQL ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cs_agent

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Agent ===
MAX_CONVERSATION_TURNS=20
RATE_LIMIT_PER_MINUTE=30

# === LangSmith (可选) ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cs-agent
